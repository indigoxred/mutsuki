<?xml version="1.0"?>
<Container version="2">
  <Name>mutsukitest</Name>
  <Repository>ghcr.io/indigoxred/mutsuki/mock-progress-bridge:latest</Repository>
  <Registry>https://github.com/indigoxred/mutsuki/pkgs/container/mutsuki%2Fmock-progress-bridge</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/indigoxred/mutsuki/issues</Support>
  <Project>https://github.com/indigoxred/mutsuki</Project>
  <ReadMe>https://github.com/indigoxred/mutsuki/blob/main/apps/mock-progress-bridge/README.md</ReadMe>
  <Overview>Mutsuki Mock Progress Bridge is a diagnostic receiver for Paperback read-event tests. It displays received read events and should not be used as the production MAL sync bridge.</Overview>
  <Category>Tools:Utilities MediaApp:Books</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/indigoxred/mutsuki/main/templates/unraid/mutsuki-mock-progress-bridge.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/indigoxred/mutsuki/main/src/ProgressBridge/static/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>1782205138</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Web UI Port" Target="8080" Default="6767" Mode="tcp" Description="Host port for the mock bridge Web UI. Container port is 8080." Type="Port" Display="always" Required="true" Mask="false">6767</Config>
  <Config Name="Appdata" Target="/data" Default="/mnt/user/appdata/mutsuki-mock-progress-bridge" Mode="rw" Description="Persistent diagnostic event storage for the mock bridge." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/mutsuki-mock-progress-bridge</Config>
</Container>
