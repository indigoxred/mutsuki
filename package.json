{
  "name": "mutsuki",
  "version": "0.1.0",
  "private": true,
  "description": "Paperback 0.9 extensions for Kavita content and MyAnimeList progress tracking.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --project tsconfig.json",
    "lint": "oxlint --type-aware --fix",
    "lint:check": "oxlint --type-aware --deny-warnings",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "bundle": "paperback-cli bundle",
    "serve": "paperback-cli serve",
    "dev": "paperback-cli serve --watch --port 5264",
    "test": "tsc --project tsconfig.test.json && node --test \"dist-tests/tests/**/*.test.js\"",
    "verify": "pnpm run format:check && pnpm run typecheck && pnpm run lint:check && pnpm run bundle && pnpm run test"
  },
  "dependencies": {
    "@paperback/runtime-polyfills": "1.0.0-alpha.92"
  },
  "devDependencies": {
    "@paperback/toolchain": "1.0.0-alpha.92",
    "@paperback/types": "1.0.0-alpha.92",
    "@types/node": "24.10.1",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.5.3",
  "repositoryName": "Mutsuki Extensions (0.9)"
}
